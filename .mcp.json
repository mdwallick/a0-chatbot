{
  "mcpServers": {
    "auth0": {
      "command": "npx",
      "args": ["-y", "@auth0/auth0-mcp-server", "init"],
      "env": {
        "DEBUG": "auth0-mcp",
        "AUTH0_DOMAIN": "${AUTH0_ISSUER_BASE_URL}",
        "AUTH0_CLIENT_ID": "${AUTH0_CLIENT_ID_MGMT}",
        "AUTH0_CLIENT_SECRET": "${AUTH0_CLIENT_SECRET_MGMT}"
      }
    }
  }
}
